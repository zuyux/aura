# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key

# Server-side Supabase access. Never expose these values in the Android app.
SUPABASE_CONNECTION_STRING=postgresql://postgres:your_password@db.your-project-ref.supabase.co:5432/postgres
SUPABASE_SECRET_KEY=sb_secret_your_key

# Pinata
PINATA_GATEWAY_URL=https://your-gateway.mypinata.cloud
NEXT_PUBLIC_PINATA_GATEWAY_URL=https://your-gateway.mypinata.cloud
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_KEY=your_pinata_secret_key
PINATA_JWT=your_pinata_jwt
PINATA_GATEWAY_KEY=your_pinata_gateway_key

# Additional Pinata compatibility variables
NEXT_PUBLIC_PINATA_API_KEY=your_pinata_api_key
NEXT_PUBLIC_PINATA_SECRET_API_KEY=your_pinata_secret_key

# Email
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=AURA <noreply@example.com>

# Server-side hashing
IP_HASH_SECRET=replace_with_a_long_random_secret
